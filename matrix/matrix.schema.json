{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leb.dev/schemas/matrix.schema.json",
  "title": "LEB Official Failure Matrix",
  "description": "Gabarito oculto de uma instância LEB (SPEC 1.1.0, matrix/MATRIX.md)",
  "type": "object",
  "required": ["leb_spec", "instance", "level", "version", "entries"],
  "properties": {
    "leb_spec": { "type": "string", "description": "Versão da spec LEB (SemVer)", "examples": ["1.0.0"] },
    "instance": { "type": "string", "description": "ID da instância", "examples": ["LEB-200-A"] },
    "level": { "type": "integer", "enum": [100, 200, 300, 400, 500] },
    "version": { "type": "string", "description": "Versão da instância (SemVer)" },
    "language": { "type": "string", "description": "Linguagem/stack do código legado", "examples": ["php7", "java8", "python2"] },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "exists"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(SEC|ARCH|PERF|BUG|CLN)-\\d{3}(\\.[a-z])?$",
            "description": "ID da taxonomia, sufixo .a/.b para plantios múltiplos da mesma classe"
          },
          "exists": { "type": "boolean", "description": "false = isca (reportar dispara PEN-004)" },
          "severity": { "type": "string", "enum": ["Crítica", "Alta", "Média", "Baixa"], "description": "Impacto — define os pontos-base (SCORING.md §1)" },
          "difficulty": { "type": "string", "enum": ["Fácil", "Moderada", "Difícil", "Especialista"], "description": "Discoverability (quão difícil de achar). Ortogonal à severidade; NÃO afeta pontos. Alimenta o eixo de descoberta do scorecard (SCORING.md §9.2)" },
          "points": { "type": "integer", "minimum": 0, "description": "Pontos-base conforme SCORING.md §1" },
          "template": { "type": "string", "enum": ["C", "R"], "description": "C = correção (5 critérios), R = refatoração (4 critérios)" },
          "location": { "type": "string", "description": "arquivo:linha ou arquivo:início-fim", "examples": ["code/src/relatorio.php:88"] },
          "evidence": { "type": "string", "description": "Trecho/sintoma que caracteriza a falha" },
          "expected_fix": { "type": "string", "description": "Correção/estrutura-alvo canônica" },
          "verify": { "type": "string", "description": "Caminho do teste de verificação em private/verify/" },
          "notes": { "type": "string", "description": "Equivalentes aceitos, armadilhas de avaliação" }
        },
        "allOf": [
          {
            "if": { "properties": { "exists": { "const": true } } },
            "then": { "required": ["severity", "difficulty", "points", "template", "location", "evidence", "expected_fix"] }
          }
        ]
      }
    },
    "public_surface": {
      "type": "object",
      "description": "Superfície de contrato declarada (espelha manifest.md) usada na verificação COMP",
      "properties": {
        "symbols": { "type": "array", "items": { "type": "string" } },
        "routes": { "type": "array", "items": { "type": "string" } },
        "db_schema": { "type": "array", "items": { "type": "string" } },
        "artifacts": { "type": "array", "items": { "type": "string" }, "description": "HTML/CSV/relatórios com formato contratado" }
      }
    }
  }
}
